{
  "name": "web-vim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "setup:wasm": "wasm-pack --version",
    "build:wasm": "wasm-pack build crates/tui-engine --target web --release --out-dir pkg",
    "build": "pnpm run build:wasm && tsc -b && vite build",
    "preview": "vite preview",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "solid-js": "^1.9.11",
    "virtual-keyboard": "workspace:*",
    "@web-vim/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
