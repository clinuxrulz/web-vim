{
  "name": "@net-vim/core",
  "version": "0.5.2",
  "description": "Vim-compatible editor engine and component library for the web.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clinuxrulz/net-vim.git",
    "directory": "packages/net-vim"
  },
  "keywords": [
    "vim",
    "neovim",
    "vi",
    "editor",
    "tui",
    "terminal",
    "webgl",
    "solidjs",
    "component",
    "modal-editing",
    "opfs",
    "code-editor",
    "browser-editor"
  ],
  "author": "clinuxrulz",
  "license": "MIT",
  "homepage": "https://github.com/clinuxrulz/net-vim#readme",
  "bugs": {
    "url": "https://github.com/clinuxrulz/net-vim/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "solid": "./src/index.tsx",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "sync-wasm": "cp -r ../../crates/tui-engine/pkg/* ./src/wasm/",
    "build": "npm run sync-wasm && vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@net-vim/virtual-keyboard": "workspace:*",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
